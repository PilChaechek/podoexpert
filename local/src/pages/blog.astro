---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import news1 from '../assets/images/news/1.webp';
import news2 from '../assets/images/news/2.webp';
import news3 from '../assets/images/news/3.jpg';

const PAGE_SIZE = 6;

const newsItems = [
  {
    title: 'Как ухаживать за стопами в межсезонье',
    excerpt: 'Подборка простых рекомендаций от подолога для ежедневного ухода.',
    href: '#',
    date: '27 марта 2026',
    image: news1,
  },
  {
    title: 'Разбор частых ошибок при домашнем уходе',
    excerpt: 'Рассказываем, какие привычки могут ухудшать состояние ногтей и кожи.',
    href: '#',
    date: '20 марта 2026',
    image: news2,
  },
  {
    title: 'Новые профессиональные средства Arkada',
    excerpt: 'Краткий обзор новинок и для каких задач они подходят лучше всего.',
    href: '#',
    date: '12 марта 2026',
    image: news3,
  },
  {
    title: 'Подготовка к педикюру: что важно знать клиенту',
    excerpt: 'Как подготовить кожу и ногти, чтобы процедура прошла комфортно и безопасно.',
    href: '#',
    date: '5 марта 2026',
    image: news1,
  },
  {
    title: 'Когда обратиться к подологу: тревожные симптомы',
    excerpt: 'Список признаков, при которых лучше не откладывать визит к специалисту.',
    href: '#',
    date: '28 февраля 2026',
    image: news2,
  },
  {
    title: 'Уход за ногтями после грибковой инфекции',
    excerpt: 'Рекомендации по восстановлению и профилактике рецидивов.',
    href: '#',
    date: '18 февраля 2026',
    image: news3,
  },
  {
    title: 'Выбор средств для сухой кожи стоп',
    excerpt: 'На что смотреть в составе и как подобрать текстуру под сезон.',
    href: '#',
    date: '10 февраля 2026',
    image: news1,
  },
  {
    title: 'Профилактика мозолей и натоптышей',
    excerpt: 'Простые привычки и средства, которые помогают сохранить кожу мягкой.',
    href: '#',
    date: '1 февраля 2026',
    image: news2,
  },
  {
    title: 'Архив: итоги года в подологии',
    excerpt: 'Главные тенденции и исследования, на которые стоит обратить внимание.',
    href: '#',
    date: '22 января 2026',
    image: news3,
  },
];

const blogBreadcrumbs = [
  { label: 'Главная', href: '/', home: true as const },
  { label: 'AArkada', href: '/' },
  { label: 'Новости' },
];
---

<Layout title="Новости">
  <section class="section header-title">
    <div class="container">
      <Breadcrumbs items={blogBreadcrumbs} />

      <div class="header-title__center">
        <h1 class="header-title__heading text-3xl md:text-4xl font-bold">Новости</h1>
        <p class="header-title__lead text-base md:text-lg">
          Проверенные источники знаний и разные точки зрения от экспертов по подологии.
        </p>
        <form class="header-title__search" role="search" action="/blog" method="get">
          <div class="input-icon header-title__search-field">
            <span class="input-icon__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="7" />
                <path d="m20 20-3.2-3.2" stroke-linecap="round" />
              </svg>
            </span>
            <label class="sr-only" for="blog-search-q">Поиск по новостям</label>
            <input
              id="blog-search-q"
              class="input input--search-header input-icon__input"
              type="search"
              name="q"
              placeholder="Поиск..."
              autocomplete="off"
            />
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="section news" aria-label="Список новостей">
    <div class="container">
      <div class="news__grid grid gap-4 md:grid-cols-2 xl:grid-cols-3" id="news-grid">
        {
          newsItems.map((item) => (
            <article class="news-card">
              <a class="news-card__image-link" href={item.href} aria-label={item.title}>
                <Image
                  class="news-card__image"
                  src={item.image}
                  alt=""
                  width={500}
                  height={500}
                  fit="cover"
                  loading="lazy"
                />
              </a>
              <p class="news-card__date text-sm">{item.date}</p>
              <h2 class="news-card__title text-2xl font-bold">
                <a class="news-card__link" href={item.href}>
                  {item.title}
                </a>
              </h2>
              <p class="news-card__excerpt text-base">{item.excerpt}</p>
            </article>
          ))
        }
      </div>
      <nav class="pagination" id="news-pagination" aria-label="Страницы новостей"></nav>
    </div>
  </section>

  <script is:inline define:vars={{ pageSize: PAGE_SIZE }}>
    (function () {
      var grid = document.getElementById('news-grid');
      var pager = document.getElementById('news-pagination');
      if (!grid) return;
      var cards = Array.prototype.slice.call(grid.querySelectorAll('.news-card'));
      var totalPages = Math.max(1, Math.ceil(cards.length / pageSize));
      var params = new URLSearchParams(window.location.search);
      var page = parseInt(params.get('page') || '1', 10);
      if (isNaN(page) || page < 1) page = 1;
      if (page > totalPages) page = totalPages;

      function apply() {
        cards.forEach(function (card, i) {
          var show = i >= (page - 1) * pageSize && i < page * pageSize;
          if (show) card.classList.remove('hidden');
          else card.classList.add('hidden');
        });
      }

      function renderPager() {
        if (!pager) return;
        if (totalPages <= 1) {
          pager.innerHTML = '';
          return;
        }
        var html = '';
        if (page > 1) {
          html += '<a class="pagination__link" href="?page=' + (page - 1) + '">Назад</a>';
        }
        for (var i = 1; i <= totalPages; i++) {
          if (i === page) {
            html += '<span class="pagination__current" aria-current="page">' + i + '</span>';
          } else {
            html += '<a class="pagination__link" href="?page=' + i + '">' + i + '</a>';
          }
        }
        if (page < totalPages) {
          html += '<a class="pagination__link" href="?page=' + (page + 1) + '">Вперёд</a>';
        }
        pager.innerHTML = html;
      }

      apply();
      renderPager();
    })();
  </script>
</Layout>
