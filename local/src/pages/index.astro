const productsPro: ProductItem[] = [
  {
    title: "Кератолитический водный раствор Arkada's TT Sept",
    description:
      'Кератолитический водный раствор для активного отшелушивания ороговевшего слоя кожи и ногтей.',
    currentPrice: '2 100 руб.',
