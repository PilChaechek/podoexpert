---
import type { ImageMetadata } from 'astro';
import productArrowSvg from '../../assets/icons/product-arrow.svg?raw';

export interface ProductItem {
  title: string;
  currentPrice: string;
  oldPrice?: string;
  description?: string;
  badge?: string;
  image: ImageMetadata;
}

export interface Props {
  title: string;
  description: string;
  /** Класс(ы) для блока `.section-header` (модификаторы цветовой темы) */
  class?: string;
  products: ProductItem[];
}

const { title, description, class: sectionHeaderClass, products } = Astro.props;
---

<section class="section products" aria-label={title}>
  <div class="container">
    <div class:list={['section-header', 'text-center', 'mb-8', sectionHeaderClass]}>
      <h2 class="section-header__title font-bold">{title}</h2>
      <p class="section-header__text">{description}</p>
    </div>
  </div>
  <div class="container--fullwidth">


    <div class="products__swiper">

      <div class="swiper js-products-swiper">
        <div class="swiper-wrapper products__wrapper">
          {
            products.map((product) => (
                <div class="swiper-slide products__slide ">
                  <article class="product-card">
                    {product.badge && <p class="product-card__badge bg-gray-800">{product.badge}</p>}
                    <div class="product-card__media">
                      <a href="/product/" class="link block">
                        {product.image && (
                            <img
                                class="product-card__image"
                                src={product.image.src}
                                alt={product.title}
                                loading="lazy"
                                decoding="async"
                            />
                        )}
                      </a>
                    </div>
                    <div class="product-card__content">
                      <h3 class="product-card__title">{product.title}</h3>
                      {product.description && (
                          <p class="product-card__description">{product.description}</p>
                      )}
                      <div class="product-card__footer">
                        <p class="product-card__price">
                          <span class="product-card__price-current">{product.currentPrice}</span>
                          {product.oldPrice && (
                              <span class="product-card__price-old text-sm">{product.oldPrice}</span>
                          )}
                        </p>
                        <a class="product-card__button btn btn-outline" href="#contact">
                          Купить
                          <Fragment set:html={productArrowSvg} />
                        </a>
                      </div>
                    </div>

                  </article>
                </div>
            ))
          }
        </div>
      </div>

      <button class="products__nav products__nav--prev" type="button" aria-label="Предыдущий товар">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="14" viewBox="0 0 9 14" fill="none">
          <path id="Vector 9" d="M1 13L7 7L1 0.999999" stroke="currentColor" stroke-width="2"/>
        </svg>
      </button>

      <button class="products__nav products__nav--next" type="button" aria-label="Следующий товар">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="14" viewBox="0 0 9 14" fill="none">
          <path id="Vector 9" d="M1 13L7 7L1 0.999999" stroke="currentColor" stroke-width="2"/>
        </svg>
      </button>

    </div>
  </div>


</section>

<script>
  const initProductsSliders = () => {
    const SwiperConstructor = (window as { Swiper?: new (el: Element, options: unknown) => unknown }).Swiper;
    if (!SwiperConstructor) {
      return;
    }

    document.querySelectorAll('.js-products-swiper').forEach((productsSlider) => {
      const el = productsSlider as HTMLElement;
      if (el.dataset.initialized === 'true') {
        return;
      }

      const root = el.closest('.products__swiper');
      if (!root) {
        return;
      }

      const nextEl = root.querySelector('.products__nav--next');
      const prevEl = root.querySelector('.products__nav--prev');

      const swiper = new SwiperConstructor(productsSlider, {
        slidesPerView: 1.1,
        slidesOffsetBefore: 12,
        slidesOffsetAfter: 12,
        spaceBetween: 12,
        speed: 600,
        navigation: {
          nextEl,
          prevEl,
        },
        breakpoints: {
          576: {
            slidesPerView: 2,
            spaceBetween: 20,
          },
          992: {
            slidesPerView: 3,
            spaceBetween: 24,
            slidesOffsetBefore: 0,
            slidesOffsetAfter: 0,
          },
        },
      });

      if (swiper) {
        el.dataset.initialized = 'true';
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductsSliders, { once: true });
  } else {
    initProductsSliders();
  }
</script>
