---

import img1 from "../../assets/images/products/1.webp";
import img2 from "../../assets/images/products/2.webp";
import img3 from "../../assets/images/products/3.webp";
import img4 from "../../assets/images/products/4.webp";
import productArrowSvg from "../../assets/icons/product-arrow.svg?raw";

const products = [
  {
    title: "Коллагеновая сыворотка для ногтей Arkada's Serum TC16, 11мл.",
    currentPrice: '2 300руб',
    oldPrice: '3 400руб',
    badge: '',
    image: img1,
  },
  {
    title: "Набор коллагеновых сывороток для ногтей Arkada's Serum TC16",
    currentPrice: '9 540руб',
    oldPrice: '20 400руб',
    badge: 'АКЦИЯ 5+1',
    image: img2,
  },
  {
    title: "Гелевая сыворотка Arkada's Serum Gel 15 мл.",
    currentPrice: '2 700руб',
    oldPrice: '3 900руб',
    badge: '',
    image: img3,
  },
  {
    title: "Мазь для сухой кожи Arkada's Masc",
    currentPrice: '2 590руб',
    oldPrice: '2 950руб',
    badge: 'АКЦИЯ ХИТ',
    image: img4,
  },
    {
        title: "Набор коллагеновых сывороток для ногтей Arkada's Serum TC16",
        currentPrice: '9 540руб',
        oldPrice: '20 400руб',
        badge: 'АКЦИЯ 5+1',
        image: img2,
    },
];
---

<section class="section products" aria-label="Секция товаров">
  <div class="container">
    <div class="section-header text-center mb-8">
      <h2 class="section-header__title font-bold">Наши хиты продаж</h2>
      <p class="section-header__text">Проверенные продукты, пользующиеся наибольшей популярностью и доверием среди профессионалов и пациентов.</p>
    </div>

    <div class="products__swiper">

      <div class="swiper js-products-swiper">
        <div class="swiper-wrapper products__wrapper">
          {
            products.map((product) => (
                <div class="swiper-slide products__slide ">
                  <article class="product-card">
                    {product.badge && <p class="product-card__badge bg-gray-800">{product.badge}</p>}
                    <div class="product-card__media">
                      {product.image && (
                          <img
                              class="product-card__image"
                              src={product.image.src}
                              alt={product.title}
                              loading="lazy"
                              decoding="async"
                          />
                      )}
                    </div>
                    <h3 class="product-card__title">{product.title}</h3>
                    <div class="product-card__footer">
                      <p class="product-card__price">
                        <span class="product-card__price-current">{product.currentPrice}</span>
                        <span class="product-card__price-old">{product.oldPrice}</span>
                      </p>
                      <a class="product-card__button btn btn-outline" href="#contact">
                        Купить
                        <Fragment set:html={productArrowSvg} />
                      </a>
                    </div>
                  </article>
                </div>
            ))
          }
        </div>
      </div>

      <button class="products__nav products__nav--prev" type="button" aria-label="Предыдущий товар">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="14" viewBox="0 0 9 14" fill="none">
          <path id="Vector 9" d="M1 13L7 7L1 0.999999" stroke="currentColor" stroke-width="2"/>
        </svg>
      </button>

      <button class="products__nav products__nav--next" type="button" aria-label="Следующий товар">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="14" viewBox="0 0 9 14" fill="none">
          <path id="Vector 9" d="M1 13L7 7L1 0.999999" stroke="currentColor" stroke-width="2"/>
        </svg>
      </button>

    </div>


  </div>
</section>

<script>
  const initProductsSlider = () => {
    const productsSlider = document.querySelector('.js-products-swiper') as HTMLElement | null;
    const SwiperConstructor = (window as { Swiper?: new (el: Element, options: unknown) => unknown }).Swiper;
    if (!productsSlider || productsSlider.dataset.initialized === 'true' || !SwiperConstructor) {
      return;
    }

    const swiper = new SwiperConstructor(productsSlider, {
      slidesPerView: 1,
      spaceBetween: 16,
      speed: 600,
      navigation: {
        nextEl: '.products__nav--next',
        prevEl: '.products__nav--prev',
      },
      breakpoints: {
        576: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
        992: {
          slidesPerView: 3,
          spaceBetween: 24,
        },
      },
    });

    if (swiper) {
      productsSlider.dataset.initialized = 'true';
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductsSlider, { once: true });
  } else {
    initProductsSlider();
  }
</script>